{
  "$schema": "https://raw.githubusercontent.com/devcxl/intelliagent/main/schemas/intelliagent.schema.json",
  "llm": {
    "api_key": "{env:OPENAI_API_KEY}",
    "base_url": "{env:OPENAI_API_BASE}",
    "model": "{env:OPENAI_MODEL:gpt-4o-mini}"
  },
  "workspace": {
    "dir": "{env:WORKSPACE_DIR:.}"
  },
  "database": {
    "url": "{env:DATABASE_URL:sqlite:///intelliagent.db}"
  },
  "permissions": {
    "rules": [
      {"pattern": "read *", "action": "allow"},
      {"pattern": ".env*", "action": "deny"},
      {"pattern": ".env.*", "action": "deny"},
      {"pattern": ".env.example", "action": "allow"},
      {"pattern": "bash *", "action": "ask"},
      {"pattern": "edit *", "action": "ask"},
      {"pattern": "write *", "action": "ask"},
      {"pattern": "git *", "action": "allow"},
      {"pattern": "grep *", "action": "allow"}
    ],
    "external_directories": []
  },
  "mcp": {
    "servers": [
      {
        "name": "filesystem",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
        "env": {}
      },
      {
        "name": "github",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"],
        "env": {
          "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
        }
      }
    ]
  }
}
